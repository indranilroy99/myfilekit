{
  "name": "myfilekit",
  "version": "3.0.24",
  "type": "module",
  "private": true,
  "description": "Privacy-first browser-based toolkit for PDF, image, business, signature, text, data, and developer utilities.",
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "vite --host 0.0.0.0 --port 4173",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "build": "vite build",
    "check": "node scripts/build-check.js",
    "test": "node --test",
    "security:audit": "node scripts/security-audit.js",
    "preflight": "npm run setup && npm run check && npm run test && npm run security:audit",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^6.0.2",
    "fflate": "^0.8.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
